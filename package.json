{
  "name": "yu-yin",
  "version": "1.0.0",
  "description": "鱼隐 - 隐蔽观赛与阅读桌面应用",
  "author": "YuYin",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.node.json && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "dist": "npm run build && electron-builder",
    "tsc:main": "tsc -p tsconfig.node.json"
  },
  "dependencies": {
    "hls.js": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  }
}
